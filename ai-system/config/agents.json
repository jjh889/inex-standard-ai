{
  "agents": {
    "planner": {
      "name": "Planner Agent",
      "description": "요구사항 분석 및 Task 분해",
      "model": "claude-sonnet-4-6",
      "temperature": 0.3,
      "maxTokens": 4096,
      "promptTemplate": "../prompts/planner-prompt.md"
    },
    "claude": {
      "name": "Claude (Dev Agent)",
      "description": "설계 + 비즈니스 로직 생성 + 단위 테스트 설계",
      "role": "설계자 — 무엇을 만들지 결정",
      "model": "claude-sonnet-4-6",
      "temperature": 0.2,
      "maxTokens": 8192,
      "promptTemplate": "../prompts/dev-prompt.md",
      "rules": {
        "linterCompliance": true,
        "minTestCoverage": 80,
        "noExternalDependencies": true,
        "transactionalForFinancial": true
      }
    },
    "codex": {
      "name": "Codex (Execution Agent)",
      "description": "코드 실행 + 수정 + 코드 리뷰(검증)",
      "role": "실행자 — 실제로 돌아가게 만듦",
      "model": "codex-mini-latest",
      "effort": "high",
      "timeout": 300000,
      "promptTemplate": "../prompts/codex-prompt.md",
      "capabilities": {
        "execute": "빌드 + 테스트 실행 + 오류 수정",
        "review": "표준 코드 리뷰 (읽기 전용)",
        "adversarialReview": "설계 결정 검증 리뷰",
        "rescue": "복잡한 문제 해결 위임"
      },
      "rules": {
        "noDesignChange": true,
        "executionLevelFixOnly": true,
        "noExternalDependencies": true,
        "reportDiffRequired": true
      }
    }
  },
  "harness": {
    "role": "오케스트레이터 — 테스트 + 검증 + 피드백 라우팅",
    "maxRetries": 3,
    "feedbackLoopEnabled": true,
    "ciTimeout": 300000,
    "logLevel": "info",
    "feedbackRouting": {
      "executionFailure": "codex",
      "ciFailure": "codex",
      "reviewReject": "claude"
    }
  },
  "approvalPolicy": {
    "general": {
      "humanApprovalRequired": 1,
      "codexReviewRequired": true
    },
    "financial": {
      "humanApprovalRequired": 2,
      "codexReviewRequired": true,
      "codexAdversarialReview": true,
      "tags": ["FINANCIAL"]
    }
  }
}
