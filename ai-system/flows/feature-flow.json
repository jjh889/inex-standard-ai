{
  "name": "feature-development-flow",
  "version": "2.0",
  "description": "AI 개발 표준 3-Agent 워크플로우 (Claude + Codex + Harness)",
  "architecture": {
    "claude": "설계 + 코드 생성 (Anthropic Claude)",
    "codex": "실행 + 수정 + 코드 리뷰 (OpenAI Codex)",
    "harness": "테스트 + 검증 + 오케스트레이션"
  },
  "states": {
    "TODO": {
      "description": "Task가 생성되어 대기 중",
      "transitions": [
        {
          "to": "PLAN_REVIEW",
          "trigger": "task_start",
          "agent": "harness"
        }
      ]
    },
    "PLAN_REVIEW": {
      "description": "AI 실행 계획을 Human이 확인/승인하는 단계",
      "agent": "human",
      "transitions": [
        {
          "to": "DESIGN",
          "trigger": "plan_approved",
          "agent": "human"
        },
        {
          "to": "FAILED",
          "trigger": "plan_rejected",
          "agent": "human"
        }
      ]
    },
    "DESIGN": {
      "description": "Claude가 설계 + 코드 생성 중",
      "agent": "claude",
      "transitions": [
        {
          "to": "CODEX_EXEC",
          "trigger": "claude_complete",
          "agent": "harness"
        }
      ]
    },
    "CODEX_EXEC": {
      "description": "Codex가 코드 실행 + 수정 중",
      "agent": "codex",
      "transitions": [
        {
          "to": "CI_TEST",
          "trigger": "codex_exec_success",
          "agent": "harness"
        },
        {
          "to": "CODEX_EXEC",
          "trigger": "codex_exec_failed",
          "agent": "harness",
          "action": "inject_execution_feedback"
        },
        {
          "to": "FAILED",
          "trigger": "max_retry_exceeded",
          "agent": "harness"
        }
      ]
    },
    "CI_TEST": {
      "description": "Harness가 CI 파이프라인으로 테스트 + 검증 중",
      "agent": "harness",
      "transitions": [
        {
          "to": "REVIEW",
          "trigger": "ci_passed",
          "agent": "harness"
        },
        {
          "to": "CODEX_EXEC",
          "trigger": "ci_failed",
          "agent": "harness",
          "action": "inject_ci_feedback_to_codex"
        }
      ]
    },
    "REVIEW": {
      "description": "Codex가 코드 리뷰(검증) 수행 중",
      "agent": "codex",
      "transitions": [
        {
          "to": "DONE",
          "trigger": "review_approved",
          "agent": "codex"
        },
        {
          "to": "DESIGN",
          "trigger": "review_rejected",
          "agent": "harness",
          "action": "inject_review_feedback_to_claude",
          "note": "설계 레벨 문제 → Claude에게 피드백하여 재설계"
        }
      ]
    },
    "DONE": {
      "description": "전체 파이프라인 통과, Human 최종 승인 대기",
      "transitions": [
        {
          "to": "MERGED",
          "trigger": "human_approved",
          "agent": "human"
        }
      ],
      "notifications": [
        {
          "channel": "slack",
          "message": "PR이 Claude 설계 + Codex 실행 + Harness 검증을 모두 통과했습니다. Human 승인을 기다리고 있습니다."
        }
      ]
    },
    "MERGED": {
      "description": "Human 승인 후 Merge 완료",
      "terminal": true,
      "notifications": [
        { "channel": "slack", "message": "PR이 Merge되었습니다." },
        { "channel": "jira", "action": "transition_to_done" }
      ]
    },
    "FAILED": {
      "description": "3회 반복 실패, 개발자 수동 개입 필요",
      "terminal": true,
      "notifications": [
        {
          "channel": "slack",
          "message": "🚨 Task {{task_id}}가 3회 반복 실패했습니다. 개발자 수동 개입이 필요합니다.",
          "mention": true
        },
        { "channel": "jira", "action": "transition_to_failed" }
      ]
    }
  },
  "retryPolicy": {
    "maxRetries": 3,
    "feedbackInjection": true,
    "onMaxRetryExceeded": "FAILED",
    "feedbackRouting": {
      "codex_exec_fail": "codex에게 실행 오류 피드백",
      "ci_fail": "codex에게 CI 실패 피드백",
      "review_reject": "claude에게 설계 수정 피드백"
    }
  },
  "approvalPolicy": {
    "general": {
      "humanApprovalRequired": 1,
      "codexReviewRequired": true
    },
    "financial": {
      "humanApprovalRequired": 2,
      "codexReviewRequired": true,
      "codexAdversarialReview": true,
      "tags": ["FINANCIAL"]
    }
  }
}
